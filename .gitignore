*.env
.env
.env.*
secrets/
*_credentials*
*password*

# --- Editor / OS cruft ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Python ---
__pycache__/
*.py[cod]
