# Normalize line endings to LF so shell scripts and ROS files work on the Jetson
# even though they may be authored on Windows. (LF everywhere except true binaries.)
* text=auto eol=lf

*.sh    text eol=lf
*.bash  text eol=lf
*.py    text eol=lf
*.cpp   text eol=lf
*.hpp   text eol=lf
*.h     text eol=lf
*.c     text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.cfg   text eol=lf
*.repos text eol=lf

# Binary assets
*.pdf  binary
*.stl  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.bag  binary
*.mcap binary
